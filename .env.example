# ── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── CORS (production: set your real domains) ───────────────
# Leave as * for local dev; set both www and non-www in production
ALLOWED_ORIGINS=https://aihomerun.app,https://www.aihomerun.app

# ── Supabase (required for auth + session storage) ────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Optional ───────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=100
UPLOAD_DIR=uploads
FRAMES_PER_SECOND=10

# ── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── JWT (required for auth) ────────────────────────────────
JWT_SECRET=your-random-secret-at-least-32-chars

# ── CORS (production: set your real domains) ───────────────
ALLOWED_ORIGINS=https://aihomerun.app,https://www.aihomerun.app

# ── Cloudflare D1 (required for database) ──────────────────
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_D1_DATABASE_ID=your-d1-database-id
CF_API_TOKEN=your-cloudflare-api-token-with-d1-edit

# ── Cloudflare R2 (required for video storage) ─────────────
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Social login (optional) ────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id
APPLE_BUNDLE_ID=com.aihomerun.app

# ── Optional ───────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=100
UPLOAD_DIR=uploads
FRAMES_PER_SECOND=10

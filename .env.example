# ── Required ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Supabase (required for auth + database) ──────────────
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── CORS (production: set your real domains) ───────────────
ALLOWED_ORIGINS=https://aihomerun.app,https://www.aihomerun.app

# ── Cloudflare R2 (required for video storage) ─────────────
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# ── Upstash Redis (required for job queue + caching) ───────
UPSTASH_REDIS_URL=https://xxx.upstash.io
UPSTASH_REDIS_TOKEN=your-upstash-redis-token

# ── Sentry (optional, recommended for production) ──────────
SENTRY_DSN=https://xxx@sentry.io/xxx
ENVIRONMENT=development

# ── Optional ───────────────────────────────────────────────
MAX_VIDEO_SIZE_MB=100
UPLOAD_DIR=uploads
FRAMES_PER_SECOND=6
MAX_CONCURRENT_ANALYSES=3
